<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vendas Confirmadas</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/admin.css">
  </head>
  <body>
    <%- include('../../partials/navbar') %>
    <div class="container-fluid py-5">
      <div class="row">
        <!-- Navbar Lateral -->
        <nav class="col-md-3 col-lg-2 d-md-block bg-light sidebar">
          <div class="position-sticky pt-3">
            <ul class="nav flex-column">
              <li class="nav-item">
                <a class="nav-link" href="/admin/manage">
                  <i class="bi bi-house"></i> Dashboard
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/admin/products">
                  <i class="bi bi-box"></i> Produtos
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/admin/users">
                  <i class="bi bi-people"></i> Administradores
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/admin/sales/pending">
                  <i class="bi bi-cart-check"></i> Vendas Pendentes
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link active" href="/admin/sales/confirmed">
                  <i class="bi bi-check-circle"></i> Vendas Confirmadas
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/admin/sales/cancelled">
                  <i class="bi bi-x-circle"></i> Vendas Canceladas
                </a>
              </li>
              <li class="nav-item mt-3">
                <a class="nav-link" href="/logout">
                  <i class="bi bi-box-arrow-right"></i> Sair
                </a>
              </li>
            </ul>
          </div>
        </nav>

        <!-- Conteúdo Principal -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
          <div class="d-flex justify-content-between align-items-center py-4 border-bottom">
            <h1 class="h2">
              <i class="bi bi-check-circle text-success"></i> Vendas Confirmadas
            </h1>
          </div>

          <% if (sales.length === 0) { %>
            <div class="alert alert-info mt-4" role="alert">
              <i class="bi bi-info-circle"></i> Nenhuma venda confirmada no momento.
            </div>
          <% } else { %>
            <div class="table-responsive mt-4">
              <table class="table table-striped table-hover">
                <thead class="table-dark">
                  <tr>
                    <th>#</th>
                    <th>Cliente</th>
                    <th>Itens</th>
                    <th>Total</th>
                    <th>Pagamento</th>
                    <th>Data</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% sales.forEach((sale, index) => { %>
                    <tr>
                      <td><strong><%= index + 1 %></strong></td>
                      <td><%= sale.customerName %></td>
                      <td>
                        <small class="text-muted">
                          <%= sale.items.length %> item(ns)
                          <a href="#" class="badge bg-info" data-bs-toggle="modal" data-bs-target="#itemsModal<%= sale.id %>">
                            Ver detalhes
                          </a>
                        </small>
                      </td>
                      <td>
                        <span class="badge bg-success">
                          R$ <%= parseFloat(sale.total).toFixed(2).replace('.', ',') %>
                        </span>
                      </td>
                      <td><%= sale.paymentMethod %></td>
                      <td>
                        <small>
                          <%= new Date(sale.createdAt).toLocaleDateString('pt-BR') %>
                          <%= new Date(sale.createdAt).toLocaleTimeString('pt-BR') %>
                        </small>
                      </td>
                      <td>
                        <span class="badge bg-success">Confirmada</span>
                      </td>
                    </tr>

                    <!-- Modal de Itens -->
                    <div class="modal fade" id="itemsModal<%= sale.id %>" tabindex="-1">
                      <div class="modal-dialog">
                        <div class="modal-content">
                          <div class="modal-header">
                            <h5 class="modal-title">Itens da Venda #<%= sale.id %></h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                          </div>
                          <div class="modal-body">
                            <h6>Cliente: <%= sale.customerName %></h6>
                            <hr>
                            <% sale.items.forEach((item, i) => { %>
                              <div class="mb-3 pb-2 border-bottom">
                                <p class="mb-1"><strong><%= i + 1 %>. <%= item.title %></strong></p>
                                <p class="mb-1 text-muted small">
                                  Quantidade: <%= item.quantity %> | Preço: R$ <%= parseFloat(item.price).toFixed(2).replace('.', ',') %>
                                </p>
                              </div>
                            <% }); %>
                            <% if (sale.notes && sale.notes !== '...') { %>
                              <hr>
                              <p><strong>Observações:</strong></p>
                              <p class="text-muted"><%= sale.notes %></p>
                            <% } %>
                          </div>
                          <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </main>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
